---
layout: layouts/base.njk
title: Releases
pagination:
  data: collections.releases
  size: 10
  alias: items
  reverse: true
permalink: "/releases/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}"
---

<h1 class="text-2xl font-bold mb-2">🎮 Releases</h1>
<p class="text-lg mb-4">Want to play Leaves of Fate? Download a build here!</p>

{% set items = items | default([]) %}
{% if (items | length) == 0 %}
  <p class="text-gray-500 dark:text-gray-400 italic">No notes yet. Add files under <code>src/notes/</code>.</p>
{% else %}
<section>
  {% for item in items %}
  <article class="border-t border-b py-4 hover:bg-green-100 dark:hover:bg-green-700/30 transition-colors">
    <h2 class="text-lg font-semibold"><a class="u-url" href="{{ item.url }}">{{ item.data.title or 'Untitled' }}</a></h2>
    {% if item.date %}
      <time class="text-xs text-gray-500 dt-published" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate }}</time>
    {% endif %}
    {% if item.data.description %}
      <p class="mt-1 p-summary">{{ item.data.description }}</p>
    {% endif %}
  </article>
  {% endfor %}
</section>
{% endif %}
